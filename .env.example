APP_NAME="Cognos AI"
APP_VERSION="0.1.0"
ENVIRONMENT="local"
PLATFORM_ADMIN_TOKEN="local-dev-platform-admin-token"
AUTH_TOKEN_SECRET="local-dev-auth-token-secret-change-me"
AUTH_TOKEN_TTL_SECONDS=86400
DATABASE_URL="postgresql+psycopg://cognos:cognos@db:5432/cognos_ai"
DAILY_SUMMARY_SCHEDULER_ENABLED=true
DAILY_SUMMARY_SCHEDULER_INTERVAL_SECONDS=60

# Do not commit real provider credentials.
WHATSAPP_PROVIDER=""
WHATSAPP_WEBHOOK_SECRET=""

# Do not commit real AI keys.
AI_KEY_MODE="platform_managed"
OPENAI_API_KEY=""

# Media storage
# Use local_filesystem for development.
# Use s3_compatible for AWS S3, Cloudflare R2, or another S3-compatible provider.
MEDIA_STORAGE_PROVIDER="local_filesystem"
MEDIA_STORAGE_LOCAL_ROOT="media"
MEDIA_STORAGE_MAX_BYTES=104857600
MEDIA_STORAGE_DOWNLOAD_TIMEOUT_SECONDS=30
MEDIA_STORAGE_S3_BUCKET=""
MEDIA_STORAGE_S3_REGION=""
MEDIA_STORAGE_S3_ENDPOINT_URL=""
MEDIA_STORAGE_S3_PUBLIC_BASE_URL=""
MEDIA_STORAGE_S3_PREFIX=""
MEDIA_STORAGE_S3_ACCESS_KEY_ID=""
MEDIA_STORAGE_S3_SECRET_ACCESS_KEY=""
MEDIA_STORAGE_S3_PRESIGNED_URL_TTL_SECONDS=600
